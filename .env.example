ENVIRONMENT=local
PROJECT_NAME=Ambar
API_BASE_URL=http://localhost:8000
FRONTEND_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,ambar.local
DATABASE_URL=mysql+pymysql://ambar:change-me@mysql:3306/ambar
TEST_DATABASE_URL=sqlite:///./test_ambar.db
JWT_SECRET_KEY=change-this-with-a-64-char-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
INTERNAL_SERVICE_SECRET=change-this-internal-service-secret
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://ambar:change-me@rabbitmq:5672/
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=ambar
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET=ambar-documents
MAX_UPLOAD_MB=25
RATE_LIMIT_PER_MINUTE=120
NEXT_PUBLIC_API_URL=/api/v1
READ_DATABASE_URL=mysql+pymysql://ambar:change-me@mysql:3306/ambar
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800
CLUSTER_NODE_ID=ambar-local-1
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=ambar-documents
CACHE_DEFAULT_TTL_SECONDS=300
# Production hardening
AUTO_CREATE_SCHEMA=false
SEED_DEFAULT_DATA=false
WEBHOOK_SECRET_ENCRYPTION_KEY=replace-with-32-plus-random-characters
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
