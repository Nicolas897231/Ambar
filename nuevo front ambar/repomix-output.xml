/* ============================================================
   AMBAR — Design Tokens
   Todo el sistema visual vive en variables. Cambia estas y
   re-tematizas la plataforma completa (color, tipo, radio, sombra).
   ============================================================ */

:root {
  /* ---- Marca: escala ámbar (AMBAR = ámbar) ---- */
  --amber-50:  oklch(0.97 0.025 78);
  --amber-100: oklch(0.94 0.05 76);
  --amber-200: oklch(0.89 0.09 74);
  --amber-300: oklch(0.84 0.12 72);
  --amber-400: oklch(0.78 0.145 68);
  --amber-500: oklch(0.72 0.155 64);   /* primario */
  --amber-600: oklch(0.64 0.145 58);
  --amber-700: oklch(0.54 0.12 52);
  --amber-800: oklch(0.44 0.095 48);
  --amber-900: oklch(0.34 0.07 46);

  /* ---- Acentos data-viz (misma L/C, varía H) ---- */
  --viz-amber:  oklch(0.74 0.15 66);
  --viz-teal:   oklch(0.72 0.12 195);
  --viz-indigo: oklch(0.62 0.16 270);
  --viz-rose:   oklch(0.68 0.17 12);
  --viz-green:  oklch(0.72 0.15 150);
  --viz-violet: oklch(0.66 0.17 305);
  --viz-sky:    oklch(0.74 0.13 235);
  --viz-gold:   oklch(0.80 0.13 88);

  /* ---- Semánticos ---- */
  --ok:      oklch(0.62 0.13 152);
  --ok-bg:   oklch(0.95 0.04 152);
  --warn:    oklch(0.74 0.15 70);
  --warn-bg: oklch(0.95 0.05 78);
  --danger:  oklch(0.58 0.18 22);
  --danger-bg: oklch(0.95 0.04 22);
  --info:    oklch(0.62 0.13 245);
  --info-bg: oklch(0.95 0.035 245);

  /* ---- Tipografía ---- */
  --font-display: "Bricolage Grotesque", "Public Sans", system-ui, sans-serif;
  --font-body: "Public Sans", system-ui, -apple-system, sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, "SF Mono", monospace;

  --fs-2xs: 11px;
  --fs-xs: 12px;
  --fs-sm: 13px;
  --fs-base: 14px;
  --fs-md: 15px;
  --fs-lg: 17px;
  --fs-xl: 20px;
  --fs-2xl: 25px;
  --fs-3xl: 32px;
  --fs-4xl: 42px;
  --fs-5xl: 56px;

  --lh-tight: 1.1;
  --lh-snug: 1.3;
  --lh-normal: 1.55;

  /* ---- Espaciado (base 4px) ---- */
  --s1: 4px;  --s2: 8px;  --s3: 12px; --s4: 16px;
  --s5: 20px; --s6: 24px; --s7: 32px; --s8: 40px;
  --s9: 48px; --s10: 64px; --s12: 96px;

  /* ---- Radios ---- */
  --r-sm: 7px;
  --r-md: 11px;
  --r-lg: 16px;
  --r-xl: 22px;
  --r-pill: 999px;

  /* ---- Geometría layout ---- */
  --sidebar-w: 268px;
  --sidebar-collapsed-w: 76px;
  --topbar-h: 66px;
  --content-max: 1480px;

  /* ---- Transiciones ---- */
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
  --t-fast: 0.16s;
  --t-med: 0.28s;
  --t-slow: 0.5s;
}

/* ===================== TEMA CLARO ===================== */
:root,
[data-theme="light"] {
  color-scheme: light;

  --bg: oklch(0.985 0.004 80);
  --bg-tint: oklch(0.97 0.008 78);
  --panel: #ffffff;
  --panel-2: oklch(0.975 0.006 80);
  --panel-3: oklch(0.96 0.008 78);
  --elevated: #ffffff;

  --text: oklch(0.25 0.012 60);
  --text-strong: oklch(0.18 0.014 55);
  --muted: oklch(0.55 0.012 60);
  --faint: oklch(0.68 0.01 65);

  --line: oklch(0.92 0.006 75);
  --line-strong: oklch(0.86 0.008 72);

  --brand: var(--amber-600);
  --brand-bright: var(--amber-500);
  --brand-ink: var(--amber-800);
  --brand-ghost: oklch(0.95 0.04 76);
  --on-brand: #ffffff;

  /* Sidebar espresso cálido */
  --side-bg: oklch(0.22 0.018 58);
  --side-bg-2: oklch(0.26 0.02 58);
  --side-text: oklch(0.86 0.012 75);
  --side-muted: oklch(0.66 0.014 70);
  --side-line: oklch(0.32 0.02 58);
  --side-active: oklch(0.30 0.03 60);

  --shadow-xs: 0 1px 2px oklch(0.4 0.02 60 / 0.06);
  --shadow-sm: 0 1px 3px oklch(0.4 0.02 60 / 0.08), 0 1px 2px oklch(0.4 0.02 60 / 0.04);
  --shadow-md: 0 4px 14px oklch(0.4 0.02 60 / 0.08), 0 2px 4px oklch(0.4 0.02 60 / 0.05);
  --shadow-lg: 0 12px 34px oklch(0.35 0.02 60 / 0.12), 0 4px 10px oklch(0.35 0.02 60 / 0.06);
  --shadow-xl: 0 28px 64px oklch(0.3 0.02 60 / 0.18);
  --glow-brand: 0 6px 22px oklch(0.64 0.145 58 / 0.32);

  --grid-line: oklch(0.91 0.006 75);
  --scrim: oklch(0.2 0.02 60 / 0.42);
}

/* ===================== TEMA OSCURO ===================== */
[data-theme="dark"] {
  color-scheme: dark;

  --bg: oklch(0.17 0.008 65);
  --bg-tint: oklch(0.19 0.01 64);
  --panel: oklch(0.215 0.011 64);
  --panel-2: oklch(0.245 0.012 64);
  --panel-3: oklch(0.275 0.013 62);
  --elevated: oklch(0.25 0.013 63);

  --text: oklch(0.94 0.006 80);
  --text-strong: oklch(0.98 0.005 85);
  --muted: oklch(0.70 0.012 75);
  --faint: oklch(0.58 0.012 70);

  --line: oklch(0.32 0.012 64);
  --line-strong: oklch(0.4 0.014 64);

  --brand: var(--amber-400);
  --brand-bright: var(--amber-300);
  --brand-ink: var(--amber-200);
  --brand-ghost: oklch(0.32 0.05 62);
  --on-brand: oklch(0.2 0.03 55);

  --side-bg: oklch(0.145 0.008 64);
  --side-bg-2: oklch(0.185 0.01 62);
  --side-text: oklch(0.84 0.012 75);
  --side-muted: oklch(0.6 0.014 70);
  --side-line: oklch(0.28 0.014 62);
  --side-active: oklch(0.27 0.02 60);

  --ok-bg:   oklch(0.28 0.05 152);
  --warn-bg: oklch(0.3 0.06 70);
  --danger-bg: oklch(0.3 0.07 22);
  --info-bg: oklch(0.28 0.05 245);
  --brand-ghost: oklch(0.3 0.05 62);

  --shadow-xs: 0 1px 2px oklch(0 0 0 / 0.3);
  --shadow-sm: 0 1px 3px oklch(0 0 0 / 0.4);
  --shadow-md: 0 4px 16px oklch(0 0 0 / 0.4);
  --shadow-lg: 0 14px 38px oklch(0 0 0 / 0.5);
  --shadow-xl: 0 30px 70px oklch(0 0 0 / 0.6);
  --glow-brand: 0 6px 26px oklch(0.78 0.145 68 / 0.3);

  --grid-line: oklch(0.3 0.012 64);
  --scrim: oklch(0.08 0.01 60 / 0.66);
}
