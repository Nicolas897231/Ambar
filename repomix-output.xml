        {area && <path d={fill} fill={`url(#${gid})`} style={{ opacity: seen ? 1 : 0, transition: "opacity .8s ease .3s" }} />}
        <path d={line} fill="none" stroke={color} strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"
