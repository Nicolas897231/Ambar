        <text x={c} y={c - 4} textAnchor="middle" fontSize="22" fontWeight="800" fill="var(--text-strong)" fontFamily="var(--font-display)">{value}%</text>
      </svg>
      {label && <span className="muted" style={{ fontSize: "var(--fs-xs)" }}>{label}</span>}
    </div>
