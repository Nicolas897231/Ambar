          <div className="col gap2">
            {[["Contrato.pdf", "pdf", "2.4 MB"], ["Anexo_certificado.jpg", "jpg", "880 KB"], ["Soportes.zip", "zip", "5.1 MB"]].slice(0, doc.files).map(([n, k, sz]) => {
              const [c, lbl] = FILE_KINDS[k];
