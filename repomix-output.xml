<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AMBAR · Mapa de Pantallas & Arquitectura</title>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Public+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="styles/tokens.css" />
  <link rel="stylesheet" href="styles/base.css" />
  <link rel="stylesheet" href="styles/components.css" />
  <link rel="stylesheet" href="styles/modules.css" />
  <link rel="stylesheet" href="styles/animations.css" />
  <style>
    body { padding: 0; }
    .map-wrap { max-width: 1280px; margin: 0 auto; padding: var(--s7) var(--s6) var(--s10); }
    .map-hero { border-radius: var(--r-xl); padding: var(--s8) var(--s7); color: #fff; background: linear-gradient(125deg, var(--amber-800), var(--amber-600) 55%, var(--amber-400)); position: relative; overflow: hidden; margin-bottom: var(--s7); }
    .map-hero h1 { color: #fff; font-size: clamp(30px, 4vw, 46px); }
    .map-hero p { color: rgba(255,255,255,.85); max-width: 64ch; margin-top: var(--s3); font-size: var(--fs-lg); }
    .sec-title { display: flex; align-items: center; gap: var(--s3); margin: var(--s8) 0 var(--s4); }
    .sec-title .n { width: 30px; height: 30px; border-radius: 9px; background: var(--brand); color: var(--on-brand); display: grid; place-items: center; font-family: var(--font-display); font-weight: 800; }
    .sec-title h2 { font-size: var(--fs-2xl); }
    .grp { border: 1px solid var(--line); border-radius: var(--r-lg); overflow: hidden; margin-bottom: var(--s4); background: var(--panel); }
    .grp-head { display: flex; align-items: center; gap: var(--s3); padding: var(--s4) var(--s5); background: var(--panel-2); border-bottom: 1px solid var(--line); }
    .grp-head .gi { width: 34px; height: 34px; border-radius: var(--r-md); background: var(--brand-ghost); color: var(--brand); display: grid; place-items: center; }
    .grp-head h3 { font-size: var(--fs-lg); }
    .screen-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--s3); padding: var(--s4); }
    .screen { display: block; border: 1px solid var(--line); border-radius: var(--r-md); padding: var(--s4); transition: all var(--t-fast); background: var(--panel); cursor: pointer; }
    .screen:hover { border-color: var(--brand); box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .screen .st { display: flex; align-items: center; gap: var(--s2); }
    .screen .st .si { width: 30px; height: 30px; border-radius: 8px; background: var(--panel-3); color: var(--brand); display: grid; place-items: center; flex-shrink: 0; }
    .screen h4 { font-size: var(--fs-md); }
    .screen p { color: var(--muted); font-size: var(--fs-sm); margin-top: var(--s2); }
    .screen .roles { display: flex; flex-wrap: wrap; gap: 4px; margin-top: var(--s3); }
    .flow { display: flex; align-items: stretch; gap: 0; overflow-x: auto; padding: var(--s2) 0; }
    .flow-step { min-width: 150px; border: 1px solid var(--line); border-radius: var(--r-md); padding: var(--s3) var(--s4); background: var(--panel); position: relative; }
    .flow-step .fs-n { font-size: var(--fs-2xs); color: var(--brand); font-weight: 700; }
    .flow-step .fs-t { font-weight: 600; font-size: var(--fs-sm); margin-top: 2px; }
    .flow-step .fs-d { font-size: var(--fs-xs); color: var(--muted); margin-top: 3px; }
    .flow-arrow { display: grid; place-items: center; color: var(--faint); padding: 0 var(--s2); flex-shrink: 0; }
    .flow-card { border: 1px solid var(--line); border-radius: var(--r-lg); padding: var(--s5); margin-bottom: var(--s4); background: var(--panel); }
    .flow-card h3 { font-size: var(--fs-md); margin-bottom: var(--s3); display: flex; align-items: center; gap: var(--s2); }
    svg.ic { width: 18px; height: 18px; }
  </style>
</head>
<body>
  <div class="map-wrap">
    <div class="map-hero">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;position:relative">
        <div class="side-logo" style="width:42px;height:42px"></div>
        <div><div style="font-family:var(--font-display);font-weight:800;font-size:22px;color:#fff">AMBAR</div><div style="font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.6)">SGDEA Enterprise</div></div>
      </div>
      <h1>Mapa de pantallas & arquitectura</h1>
      <p>Vista completa del sistema AMBAR: estructura de navegación, catálogo de todas las pantallas con su acceso por rol, y los flujos de negocio clave. Haz clic en cualquier pantalla para abrirla en el prototipo navegable.</p>
      <div style="display:flex;gap:10px;margin-top:24px;position:relative">
        <a class="btn btn-secondary" href="index.html" style="background:rgba(255,255,255,.16);color:#fff;border-color:rgba(255,255,255,.25)">Abrir prototipo navegable</a>
        <a class="btn btn-secondary" href="index.html#/empleo" style="background:rgba(255,255,255,.16);color:#fff;border-color:rgba(255,255,255,.25)">Ver portal de empleo</a>
      </div>
    </div>
    <div id="content"></div>
  </div>

  <script src="js/icons.js"></script>
  <script src="js/data.js"></script>
  <script>
    function svg(name, cls) { return `<svg class="ic ${cls||''}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${window.ICONS[name]||window.ICONS.circle}</svg>`; }
    const SCREEN_DESC = {
      dashboard: "KPIs, gráficas, actividad reciente, tareas y vencimientos — adaptado al rol.",
      expedients: "Entidad principal: agrupa documentos por empleado, cliente, proveedor, contrato o proceso. Vista CRM, árbol documental y completitud.",
      documents: "Tabla avanzada con filtros, detalle por pestañas (info, archivos, versiones, OCR, ubicación) y registro guiado.",
      digitization: "Cola Kanban, escaneo masivo con drag & drop y resultado OCR estilo Google Vision.",
      trd: "Series y subseries, tiempos de retención y disposición final.",
      archive: "Consulta rápida de ubicación, mapa tipo bodega, gestión de cajas y carpetas.",
      transfers: "Asistente de 6 pasos con FUID, recepción ítem por ítem y cierre idempotente.",
      loans: "Solicitud → aprobación → entrega → devolución → cierre, con alertas de vencimiento.",
      correspondence: "Radicación entrante/saliente, bandeja por estado y seguimiento del trámite.",
      hr: "Empleados con perfil 360°, perfiles de cargo, contratos y dependencias.",
      medical: "Exámenes de ingreso, periódico, reintegro y retiro con alertas y calendario.",
      recruitment: "Pipeline Kanban, base de talentos y vacantes — conectado al portal público.",
      reports: "Tableros BI por área de negocio, exportación y reportes programados.",
      audit: "Registro de cada acción: quién, qué, cuándo, desde dónde y resultado.",
      security: "Usuarios, roles y matriz de permisos por módulo y acción.",
      settings: "Apariencia configurable en vivo, integraciones, firmas y automatización.",
    };
    const EXTRA = [
      { group: "Acceso & Sesión", icon: "lock", items: [
        { key: "", icon: "log-in", label: "Login multi-usuario", desc: "Ingreso con cuenta corporativa y acceso rápido por rol.", roles: ["Todos"] },
        { key: "", icon: "fingerprint", label: "Verificación MFA", desc: "Segundo factor para usuarios con autenticación reforzada.", roles: ["Todos"] },
        { key: "", icon: "key-round", label: "Recuperar contraseña", desc: "Envío de enlace seguro de restablecimiento.", roles: ["Todos"] },
        { key: "", icon: "user-check", label: "Activar cuenta", desc: "Onboarding en 2 pasos por invitación del administrador.", roles: ["Todos"] },
        { key: "empleo", icon: "briefcase", label: "Portal público de empleo", desc: "Landing, vacantes y registro de candidatos (sin login).", roles: ["Público"] },
      ]},
    ];

    function rolesFor(perms) {
      if (!perms) return ["Todos"];
      return Object.values(window.ROLES).filter(r => r.perms === "*" || perms.some(p => r.perms.includes(p))).map(r => r.name);
    }

    let html = "";
    // Section 1: Architecture
    html += `<div class="sec-title"><span class="n">1</span><h2>Arquitectura de navegación</h2></div>`;
    window.NAV.forEach(g => {
      html += `<div class="grp"><div class="grp-head"><span class="gi">${svg(g.icon)}</span><h3>${g.label}</h3><span class="badge badge-outline" style="margin-left:auto">${g.items.length} pantallas</span></div><div class="screen-grid">`;
      g.items.forEach(it => {
        const roles = rolesFor(it.perms);
        const shown = roles.length >= Object.keys(window.ROLES).length ? ["Todos los roles"] : roles.slice(0, 4);
        html += `<a class="screen" href="index.html#/${it.key}"><div class="st"><span class="si">${svg(it.icon)}</span><h4>${it.label}</h4></div><p>${SCREEN_DESC[it.key]||""}</p><div class="roles">${shown.map(r=>`<span class="badge badge-brand">${r}</span>`).join("")}${roles.length>4 && shown[0]!=="Todos los roles"?`<span class="badge badge-outline">+${roles.length-4}</span>`:""}</div></a>`;
      });
      html += `</div></div>`;
    });
    // Extra screens (auth + portal)
    EXTRA.forEach(g => {
      html += `<div class="grp"><div class="grp-head"><span class="gi">${svg(g.icon)}</span><h3>${g.group}</h3><span class="badge badge-outline" style="margin-left:auto">${g.items.length} pantallas</span></div><div class="screen-grid">`;
      g.items.forEach(it => {
        html += `<a class="screen" href="index.html${it.key?'#/'+it.key:''}"><div class="st"><span class="si">${svg(it.icon)}</span><h4>${it.label}</h4></div><p>${it.desc}</p><div class="roles">${it.roles.map(r=>`<span class="badge ${r==='Público'?'badge-info':'badge-brand'}">${r}</span>`).join("")}</div></a>`;
      });
      html += `</div></div>`;
    });

    // Section 2: User flows
    const FLOWS = [
      { name: "Recepción documental", icon: "inbox", steps: [["1","Recepción","Llega o se genera"],["2","Radicación","N° consecutivo"],["3","Clasificación","Serie / TRD"],["4","Digitalización","Escaneo + OCR"],["5","Indexación","Metadatos"],["6","Ubicación","Caja / carpeta"],["7","Distribución","Notifica al área"]] },
      { name: "Contratación (candidato → empleado)", icon: "user-plus", steps: [["1","Postulación","Portal / RRHH"],["2","Pipeline","Etapas de selección"],["3","Aprobación","Jefe de RRHH"],["4","Hire","Crea empleado"],["5","Reutiliza docs","HV al expediente"],["6","Onboarding","Checklist + examen"]] },
      { name: "Transferencia documental", icon: "route", steps: [["1","Seleccionar","Expedientes"],["2","FUID","Inventario auto"],["3","Validar","Archivo receptor"],["4","Transferir","Traslado físico"],["5","Recibir","Ítem por ítem"],["6","Cerrar lote","Actualiza ubicación"]] },
      { name: "Préstamo documental", icon: "package-check", steps: [["1","Solicitud","Razón + fecha"],["2","Aprobación","Jefe de Archivo"],["3","Entrega","Con constancia"],["4","Devolución","Verifica estado"],["5","Cierre","Actualiza Kardex"]] },
      { name: "Exámenes médicos (SST)", icon: "stethoscope", steps: [["1","Programación","Según cargo"],["2","Notificación","Empleado + jefe"],["3","Realización","IPS emite apto"],["4","Carga resultado","PDF + resultado"],["5","Vencimiento","Alerta 30 días"]] },
    ];
    html += `<div class="sec-title"><span class="n">2</span><h2>Flujos de negocio (user flows)</h2></div>`;
    FLOWS.forEach(f => {
      html += `<div class="flow-card"><h3>${svg(f.icon)} ${f.name}</h3><div class="flow">`;
      f.steps.forEach((s, i) => {
        html += `<div class="flow-step"><div class="fs-n">PASO ${s[0]}</div><div class="fs-t">${s[1]}</div><div class="fs-d">${s[2]}</div></div>`;
        if (i < f.steps.length - 1) html += `<div class="flow-arrow">${svg("chevron-right")}</div>`;
      });
      html += `</div></div>`;
    });

    // Section 3: Roles
    html += `<div class="sec-title"><span class="n">3</span><h2>Roles y accesos</h2></div><div class="screen-grid" style="padding:0">`;
    Object.entries(window.ROLES).forEach(([k, r]) => {
      const count = r.perms === "*" ? window.ALL_PERMS.length : r.perms.length;
      html += `<div class="screen" style="cursor:default"><div class="st"><span class="role-swatch" style="background:${r.color};height:30px;width:10px"></span><h4>${r.name}</h4></div><p>${r.desc}</p><div class="roles"><span class="badge badge-outline">${r.area}</span><span class="badge badge-brand">${count} permisos</span></div></div>`;
    });
    html += `</div>`;

    document.getElementById("content").innerHTML = html;
  </script>
</body>
</html>
