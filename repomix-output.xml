        <>
          <div className="mfa-badge"><Icon name="key-round" size={24} /></div>
          <h2>Recuperar contraseña</h2>
          <p className="muted" style={{ marginBottom: "var(--s5)" }}>Te enviaremos un enlace seguro para restablecer tu contraseña.</p>
