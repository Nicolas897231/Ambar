.tree-node { min-height: 44px; display: flex; align-items: center; gap: 10px; padding: 10px 12px; border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--panel); }
.platform-hero { display: grid; grid-template-columns: minmax(0, 1fr) minmax(240px, 320px); align-items: center; gap: 24px; }
.platform-hero h2 { font-size: clamp(1.7rem, 2vw, 2.4rem); margin: 4px 0 8px; }
.platform-signal { min-height: 180px; display: grid; place-items: center; align-content: center; gap: 8px; border: 1px solid var(--line); border-radius: var(--radius-md); background: var(--surface); text-align: center; }
.platform-signal strong { font-size: 1.35rem; }
.checklist { display: flex; flex-wrap: wrap; gap: 8px; }
.service-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 12px; }
.service-card { display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 14px; border: 1px solid var(--line); border-radius: var(--radius-md); background: var(--panel); }
.full-span { grid-column: 1 / -1; }
.jobs-page { min-height: 100vh; background: var(--surface); color: var(--text); padding: clamp(18px, 3vw, 42px); display: grid; gap: 20px; align-content: start; }
.jobs-hero { display: flex; justify-content: space-between; align-items: flex-start; gap: 18px; max-width: 1240px; width: 100%; margin: 0 auto; }
.jobs-hero h1 { font-size: clamp(2rem, 3vw, 3.2rem); margin: 6px 0 8px; letter-spacing: 0; }
.jobs-hero p { max-width: 720px; color: var(--muted); margin: 0; }
.jobs-layout { width: 100%; max-width: 1240px; margin: 0 auto; display: grid; grid-template-columns: minmax(320px, 420px) minmax(0, 1fr); gap: 18px; align-items: start; }
.jobs-list, .jobs-apply { display: grid; gap: 12px; }
.job-card { min-height: 116px; display: grid; gap: 6px; align-content: start; text-align: left; background: var(--panel); color: var(--text); border: 1px solid var(--line); border-radius: var(--radius-md); padding: 14px; }
.job-card span, .job-card small { color: var(--muted); }
.job-card.active, .job-card:hover { border-color: color-mix(in srgb, var(--brand) 52%, var(--line)); box-shadow: inset 3px 0 0 var(--brand); background: var(--surface-hover); }
.jobs-apply form { gap: 12px; }
.role-matrix { display: grid; border: 1px solid var(--line); border-radius: var(--radius-md); overflow-x: auto; }
.role-matrix-row { min-width: 760px; display: grid; grid-template-columns: minmax(180px, 1fr) repeat(5, minmax(96px, .45fr)); gap: 8px; align-items: center; padding: 10px 12px; border-top: 1px solid var(--line); background: var(--panel); }
.role-matrix-row:first-child { border-top: 0; }
.role-matrix-row.header { background: var(--surface); color: var(--muted); font-weight: 800; }
.role-matrix-row button { min-height: 36px; justify-content: center; }
.spotlight-results { display: grid; gap: 14px; }
.spotlight-group { display: grid; gap: 8px; }
.spotlight-group h3 { margin: 0; text-transform: capitalize; }
.spotlight-row { min-height: 54px; display: grid; grid-template-columns: minmax(180px, 1fr) minmax(180px, 1.2fr) auto; align-items: center; gap: 12px; padding: 10px 12px; border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--panel); color: var(--text); }
.spotlight-row:hover { background: var(--surface-hover); border-color: color-mix(in srgb, var(--brand) 35%, var(--line)); }
.document-workspace, .trd-workspace { display: grid; grid-template-columns: minmax(420px, 620px) minmax(0, 1fr); gap: 18px; align-items: start; }
.document-wizard { display: grid; gap: 16px; }
.document-steps { grid-template-columns: repeat(5, minmax(0, 1fr)); }
.document-steps .wizard-step { min-height: 58px; padding: 9px; }
.document-steps .wizard-step strong { font-size: .85rem; }
.scroll-tabs { overflow-x: auto; flex-wrap: nowrap; }
.scroll-tabs button { white-space: nowrap; }
.trd-workspace .org-tree { display: grid; gap: 12px; }
pre { max-width: 100%; overflow: auto; padding: 12px; border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--surface); color: var(--text); font-size: .85rem; }
@media (min-width: 1600px) {
  .split { grid-template-columns: minmax(360px, 440px) minmax(760px, 1fr); }
  .users-layout { grid-template-columns: minmax(620px, 780px) minmax(780px, 1fr); }
  .search-command { width: min(620px, 38vw); }
}
@media (max-width: 1200px) {
  .search-form { grid-template-columns: 1fr 1fr; }
  .search-form button { width: 100%; }
  .users-layout, .archive-access-grid { grid-template-columns: 1fr; }
  .wizard-steps { grid-template-columns: repeat(3, minmax(0, 1fr)); }
}
@media (max-width: 900px) {
  html { font-size: 16px; }
  .app-shell, .app-shell.sidebar-collapsed { grid-template-columns: 1fr; }
  .content { padding: 16px; }
  .split, .search-form, .two-columns { grid-template-columns: 1fr; }
  .form-panel { max-width: none; }
  .topbar { gap: 10px; }
  .archive-selector, .search-command { width: 100%; }
  .wizard-steps { grid-template-columns: 1fr; }
  .permission-row { grid-template-columns: 1fr; }
  .wizard-actions { flex-direction: column; }
  .wizard-actions button { width: 100%; }
  .pipeline-board { grid-template-columns: repeat(5, minmax(240px, 84vw)); }
  .context-fab { right: 16px; bottom: 16px; }
  .platform-hero { grid-template-columns: 1fr; }
  .document-workspace, .trd-workspace { grid-template-columns: 1fr; }
  .document-steps { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .spotlight-row { grid-template-columns: 1fr; }
  .metadata-grid, .foliation-hero { grid-template-columns: 1fr; }
  .jobs-hero { flex-direction: column; }
  .jobs-layout { grid-template-columns: 1fr; }
}
