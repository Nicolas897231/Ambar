            "/api/v1/documents/types",
            json={
                "type_code": type_code,
                "name": "Manifiesto de carga QA",
                "sector": "transporte",
                "subseries_id": subseries.json()[0]["idSubseries"],
                "required_metadata": ["numero_manifiesto", "placa", "conductor"],
                "optional_metadata": ["origen", "destino"],
            },
