}

function ExpedientsPage({ user, navigate }) {
  const [type, setType] = exS("");
  const [q, setQ] = exS("");
  const [detail, setDetail] = exS(null);
  const rows = EXPEDIENTS.filter(e => (!type || e.type === type) && (!q || (e.name + e.id).toLowerCase().includes(q.toLowerCase())));

  return (
    <>
