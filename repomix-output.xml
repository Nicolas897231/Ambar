<file path="nuevo front ambar/styles/animations.css">
/* ============================================================
   AMBAR — Animaciones (máximo impacto, respetando reduce-motion)
   ============================================================ */

/* Entrance keyframes are TRANSFORM-ONLY (no opacity) so content is always
   fully visible even if an animation is frozen mid-run (inactive tab / capture)
   or never starts (reduced-motion). Opacity fades are reserved for transient
   overlays that only appear on user action in an active tab. */
@keyframes rise { from { transform: translateY(20px); } to { transform: translateY(0); } }
@keyframes rise-sm { from { transform: translateY(11px); } to { transform: translateY(0); } }
@keyframes fall { from { transform: translateY(-16px); } to { transform: translateY(0); } }
@keyframes scale-in { from { transform: scale(0.965); } to { transform: scale(1); } }
@keyframes slide-right { from { transform: translateX(-22px); } to { transform: translateX(0); } }
@keyframes blur-in { from { transform: translateY(14px) scale(0.99); } to { transform: translateY(0) scale(1); } }
@keyframes pop { 0% { transform: scale(0.7); } 60% { transform: scale(1.06); } 100% { transform: scale(1); } }
@keyframes float-y { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }
@keyframes pulse-ring { 0% { box-shadow: 0 0 0 0 var(--brand-ghost); } 70% { box-shadow: 0 0 0 12px transparent; } 100% { box-shadow: 0 0 0 0 transparent; } }
@keyframes count-blur { from { filter: blur(6px); opacity: 0.3; } to { filter: blur(0); opacity: 1; } }
@keyframes draw { to { stroke-dashoffset: 0; } }
@keyframes grow-bar { from { transform: scaleY(0); } to { transform: scaleY(1); } }
@keyframes sweep { from { transform: translateX(-30px) skewX(-6deg); } to { transform: translateX(0) skewX(0); } }
@keyframes gradient-pan { 0% { background-position: 0% 50%; } 100% { background-position: 200% 50%; } }
@keyframes shine { from { transform: translateX(-120%) rotate(8deg); } to { transform: translateX(220%) rotate(8deg); } }

/* entrance helpers — base state is the VISIBLE end state. Animations only run
   once JS adds `.anim-ready` to <html> AND the user allows motion, so frozen
   captures, print and reduced-motion always show content. */
@media (prefers-reduced-motion: no-preference) {
  .anim-ready .an-rise { animation: rise var(--t-slow) var(--ease-out) both; }
  .anim-ready .an-fall { animation: fall var(--t-med) var(--ease-out) both; }
  .anim-ready .an-scale { animation: scale-in var(--t-med) var(--ease-spring) both; }
  .anim-ready .an-blur { animation: blur-in 0.6s var(--ease-out) both; }
  .anim-ready .an-pop { animation: pop var(--t-med) var(--ease-spring) both; }
  .anim-ready .an-sweep { animation: sweep var(--t-slow) var(--ease-out) both; }

  /* route transition wrapper */
  .anim-ready .route-enter { animation: blur-in 0.45s var(--ease-out) both; }

  /* stagger: set --i on children */
  .anim-ready .stagger > * { animation: rise 0.55s var(--ease-out) both; animation-delay: calc(var(--i, 0) * 0.06s + 0.05s); }
  .anim-ready .stagger-fast > * { animation: rise-sm 0.4s var(--ease-out) both; animation-delay: calc(var(--i, 0) * 0.04s); }
}

/* hero gradient text */
.grad-text { background: linear-gradient(100deg, var(--amber-600), var(--amber-400), var(--amber-700)); background-size: 200% auto; -webkit-background-clip: text; background-clip: text; color: transparent; animation: gradient-pan 6s linear infinite alternate; }

/* shine pass on cards/buttons */
.shine { position: relative; overflow: hidden; }
.shine::before { content: ""; position: absolute; top: -50%; bottom: -50%; left: 0; width: 40%; background: linear-gradient(90deg, transparent, oklch(1 0 0 / 0.18), transparent); transform: translateX(-120%) rotate(8deg); }
.shine:hover::before { animation: shine 0.9s var(--ease-out); }

.floaty { animation: float-y 5s var(--ease-in-out) infinite; }
.pulse { animation: pulse-ring 2.2s infinite; }

/* number count flash */
.flash-num { animation: count-blur 0.5s var(--ease-out) both; }

/* parallax layers for login/portal */
.parallax { will-change: transform; transition: transform 0.3s var(--ease-out); }

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: 0.001ms !important; animation-delay: 0ms !important; transition-duration: 0.05ms !important; }
  .floaty, .grad-text, .pulse { animation: none !important; }
}
</file>

<file path="nuevo front ambar/styles/auth.css">
/* ============================================================
   AMBAR — Login / Auth screens
   ============================================================ */
.auth-page { min-height: 100vh; display: grid; grid-template-columns: 1.05fr 1fr; position: relative; overflow: hidden; background: var(--side-bg); }
.auth-theme { position: fixed; top: var(--s5); right: var(--s5); z-index: 10; background: rgba(255,255,255,.08) !important; }
.auth-theme:hover { background: rgba(255,255,255,.16) !important; }

.auth-bg { position: absolute; inset: 0; overflow: hidden; z-index: 0; }
.orb { position: absolute; border-radius: 50%; filter: blur(70px); opacity: .55; will-change: transform; }
.auth-grid-overlay { position: absolute; inset: 0; background-image: linear-gradient(var(--side-line) 1px, transparent 1px), linear-gradient(90deg, var(--side-line) 1px, transparent 1px); background-size: 46px 46px; opacity: .12; mask-image: radial-gradient(ellipse at 30% 40%, black, transparent 75%); }

/* Brand panel */
.auth-brandpanel { position: relative; z-index: 2; display: flex; flex-direction: column; padding: var(--s8) var(--s9); color: #fff; gap: var(--s7); }
.auth-hero h1 { font-size: clamp(34px, 4vw, 54px); line-height: 1.05; color: #fff; letter-spacing: -0.02em; }
.auth-hero p { color: rgba(255,255,255,.66); font-size: var(--fs-lg); margin-top: var(--s4); max-width: 42ch; line-height: 1.5; }
.auth-feats { display: grid; gap: var(--s3); margin-top: var(--s6); }
.auth-feats > div { color: rgba(255,255,255,.82); font-size: var(--fs-sm); }
.af-ico { width: 30px; height: 30px; border-radius: 9px; display: grid; place-items: center; background: rgba(255,255,255,.1); color: var(--amber-300); flex-shrink: 0; }
.auth-cards { display: flex; gap: var(--s3); flex-wrap: wrap; }
.auth-cards > div { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.1); backdrop-filter: blur(8px); color: rgba(255,255,255,.9); font-size: var(--fs-xs); font-weight: 600; padding: 9px 14px; border-radius: var(--r-pill); }
.auth-cards svg { color: var(--amber-300); }

/* Form panel */
.auth-formpanel { position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: var(--s6); gap: var(--s4); background: var(--bg); }
.auth-card { width: min(420px, 100%); background: var(--panel); border: 1px solid var(--line); border-radius: var(--r-xl); padding: var(--s8) var(--s7); box-shadow: var(--shadow-xl); }
.auth-card h2 { font-size: var(--fs-2xl); }
.auth-mobile-brand { display: none; align-items: center; gap: var(--s2); margin-bottom: var(--s5); }
.auth-mobile-brand .side-logo { width: 34px; height: 34px; }
.auth-mobile-brand b { font-family: var(--font-display); font-size: var(--fs-xl); }

.pass-toggle { position: absolute; right: 6px; top: 50%; transform: translateY(-50%); width: 30px; height: 30px; display: grid; place-items: center; background: none; border: none; color: var(--faint); cursor: pointer; border-radius: 7px; }
.pass-toggle:hover { color: var(--text); background: var(--panel-2); }

.auth-link { color: var(--brand); font-weight: 600; cursor: pointer; }
.auth-link:hover { text-decoration: underline; }
.auth-error { display: flex; align-items: center; gap: 7px; color: var(--danger); background: var(--danger-bg); border: 1px solid color-mix(in oklab, var(--danger) 25%, transparent); padding: 9px 12px; border-radius: var(--r-md); font-size: var(--fs-sm); font-weight: 500; }
.auth-divider { display: flex; align-items: center; gap: var(--s3); color: var(--faint); font-size: var(--fs-xs); margin: var(--s5) 0; }
.auth-divider::before, .auth-divider::after { content: ""; flex: 1; height: 1px; background: var(--line); }
.auth-back { display: inline-flex; align-items: center; gap: 4px; background: none; border: none; color: var(--muted); font-size: var(--fs-sm); font-weight: 600; cursor: pointer; margin-bottom: var(--s4); padding: 0; }
.auth-back:hover { color: var(--text); }
.auth-foot { color: var(--muted); font-size: var(--fs-xs); }

.demo-users { display: grid; grid-template-columns: 1fr 1fr; gap: var(--s2); }
.demo-user { display: flex; align-items: center; gap: var(--s2); padding: 7px 9px; border-radius: var(--r-md); border: 1px solid var(--line); background: var(--panel-2); cursor: pointer; text-align: left; transition: all var(--t-fast); min-width: 0; }
.demo-user:hover { border-color: var(--brand); background: var(--brand-ghost); transform: translateY(-1px); box-shadow: var(--shadow-sm); }
.du-name { font-size: var(--fs-sm); font-weight: 700; color: var(--text-strong); line-height: 1.1; }
.du-role { font-size: 10px; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 110px; }

.mfa-badge { width: 56px; height: 56px; border-radius: var(--r-lg); display: grid; place-items: center; background: var(--brand-ghost); color: var(--brand); margin-bottom: var(--s4); }
.mfa-input { font-size: 32px; text-align: center; letter-spacing: 12px; height: 64px; font-weight: 700; padding-left: 12px; }

@media (max-width: 900px) {
  .auth-page { grid-template-columns: 1fr; }
  .auth-brandpanel { display: none; }
  .auth-mobile-brand { display: flex; }
  .auth-formpanel { min-height: 100vh; }
}
