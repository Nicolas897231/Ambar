const { useState: poS } = React;

const PUB_VACANCIES = [
  { title: "Desarrollador Full Stack", area: "Tecnología", type: "Tiempo completo", city: "Cali", mode: "Híbrido", salary: "$ 5–7M", tags: ["React", "Node", "SQL"] },
